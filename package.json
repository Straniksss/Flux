{
  "name": "flux-tasks",
  "productName": "Flux Tasks",
  "private": true,
  "version": "1.1.23",
  "repository": {
    "type": "git",
    "url": "https://github.com/Flux-Tasks/Flux-Tasks.git"
  },
  "homepage": "https://github.com/Flux-Tasks/Flux-Tasks#readme",
  "description": "Local-first desktop task manager with GitHub integration and background reminders.",
  "author": {
    "name": "Flux Tasks Organization",
    "url": "https://github.com/Flux-Tasks"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Flux-Tasks/Flux-Tasks/issues"
  },
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:frontend": "vite build",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --external:electron --outfile=dist-electron/main.js && esbuild electron/preload.ts --bundle --platform=node --external:electron --outfile=dist-electron/preload.js",
    "build": "npm run build:frontend && npm run build:electron && electron-builder --win",
    "build:web-installer": "node scripts/build-installer.js",
    "test:web-installer": "npm run build:web-installer && node scripts/test-web-installer.js",
    "package": "npm run build",
    "release": "node scripts/release.js",
    "upload-release": "node scripts/upload-release.js",
    "upload-web-package": "node scripts/upload-release.js --setup-only",
    "generate:update-manifest": "node scripts/generate-update-manifest.js",
    "clean": "rm -rf dist dist-electron release",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.flux.tasks",
    "productName": "Flux Tasks",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "Flux-Tasks",
      "repo": "Flux-Tasks"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Flux Tasks",
      "artifactName": "Flux Tasks Setup.${ext}"
    },
    "portable": {
      "artifactName": "Flux Tasks Portable.${ext}"
    }
  }
}